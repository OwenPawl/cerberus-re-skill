#!/usr/bin/env bash
#
# ghidra_run_script
#
# Run a Ghidra script against an existing project.
#
# Usage:
#   ghidra_run_script <project_name> <program_name> <script_name> [script args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  sed -n '3,9p' "$0"
}

[[ $# -ge 3 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
script_name="$3"
shift 3

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_require_project "$project_name"

headless="$(ghidra_re_analyze_headless_path "$GHIDRA_INSTALL_DIR")"
project_location="$(ghidra_re_project_location "$project_name")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/script-${timestamp}.log"
script_log="$log_dir/script-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
mkdir -p "$log_dir"

script_args=()
while IFS= read -r -d '' arg; do
  script_args+=("$arg")
done < <(ghidra_re_normalize_script_args "$@")

optional_args=()
while IFS= read -r -d '' arg; do
  optional_args+=("$arg")
done < <(ghidra_re_optional_headless_args)

cmd=(
  "$headless"
  "$project_location"
  "$project_name"
  "-readOnly"
)
if ! ghidra_re_flag_enabled "${GHIDRA_RUN_SCRIPT_ANALYSIS:-0}"; then
  cmd+=("-noanalysis")
fi
cmd+=("-scriptPath" "$script_path" "-postScript" "$script_name")
if [[ ${#script_args[@]} -gt 0 ]]; then
  cmd+=("${script_args[@]}")
fi
if [[ -n "$program_name" && "$program_name" != "-" ]]; then
  cmd+=("-process" "$program_name")
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
cmd+=("-log" "$log_file" "-scriptlog" "$script_log")

lock_dir="$(ghidra_re_acquire_headless_lock "$project_name" "run-script:$script_name")"
trap 'ghidra_re_release_headless_lock "$lock_dir"' EXIT
"${cmd[@]}"
ghidra_re_release_headless_lock "$lock_dir"
trap - EXIT

printf '{\n'
printf '  "ok": true,\n'
printf '  "project_name": "%s",\n' "$project_name"
printf '  "program_name": "%s",\n' "$program_name"
printf '  "script_name": "%s",\n' "$script_name"
printf '  "log": "%s",\n' "$log_file"
printf '  "script_log": "%s"\n' "$script_log"
printf '}\n'
