#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -ge 3 ]] || {
  printf 'Usage: ghidra_objc_message_flow <project_name> <program_name> <selector> [class=<ClassName>] [trace_file=<path>] [trace_json=<json>] [format=json]\n' >&2
  exit 1
}

project="$1"
program="$2"
selector="$3"
shift 3

class_name=""
trace_file=""
trace_json=""
format="json"

for arg in "$@"; do
  case "$arg" in
    class=*)      class_name="${arg#class=}" ;;
    trace_file=*) trace_file="${arg#trace_file=}" ;;
    trace_json=*) trace_json="${arg#trace_json=}" ;;
    format=*)     format="${arg#format=}" ;;
    *)            printf 'ghidra-re: warning: unknown argument: %s\n' "$arg" >&2 ;;
  esac
done

export_dir="$(ghidra_re_export_dir "$project" "$program")"
cmd=(python3 "$GHIDRA_RE_ROOT/scripts/ghidra_objc_surface_backend.py"
  --mode message_flow
  --export-dir "$export_dir"
  --query "$selector"
  --format "$format")
[[ -n "$class_name" ]] && cmd+=(--class-name "$class_name")
[[ -n "$trace_file" ]] && cmd+=(--trace-file "$trace_file")
[[ -n "$trace_json" ]] && cmd+=(--trace-json "$trace_json")

PYTHONPATH="$GHIDRA_RE_ROOT${PYTHONPATH:+:$PYTHONPATH}" "${cmd[@]}"
