#!/usr/bin/env bash
#
# ghidra_export_apple_bundle
#
# Export the standard Apple-focused JSON bundle for an existing project.
#
# Usage:
#   ghidra_export_apple_bundle <project_name> <program_name> [outdir=<path>]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  sed -n '3,10p' "$0"
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
shift 2

outdir=""
for arg in "$@"; do
  case "$arg" in
    outdir=*) outdir="${arg#outdir=}" ;;
    output=*) outdir="${arg#output=}" ;;
    *) printf 'ghidra-re: warning: unknown argument: %s\n' "$arg" >&2 ;;
  esac
done

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_require_project "$project_name"

headless="$(ghidra_re_analyze_headless_path "$GHIDRA_INSTALL_DIR")"
project_location="$(ghidra_re_project_location "$project_name")"
export_dir="${outdir:-$(ghidra_re_export_dir "$project_name" "$program_name")}"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/export-apple-bundle-${timestamp}.log"
script_log="$log_dir/export-apple-bundle-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
mkdir -p "$export_dir" "$log_dir"

optional_args=()
while IFS= read -r -d '' arg; do
  optional_args+=("$arg")
done < <(ghidra_re_optional_headless_args)

cmd=(
  "$headless"
  "$project_location"
  "$project_name"
  "-readOnly"
)
if ! ghidra_re_flag_enabled "${GHIDRA_RUN_SCRIPT_ANALYSIS:-0}"; then
  cmd+=("-noanalysis")
fi
cmd+=(
  "-scriptPath" "$script_path"
  "-postScript" "ExportAppleBundle.java" "outdir=$export_dir"
  "-process" "$program_name"
)
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
cmd+=("-log" "$log_file" "-scriptlog" "$script_log")

lock_dir="$(ghidra_re_acquire_headless_lock "$project_name" "export-apple-bundle")"
trap 'ghidra_re_release_headless_lock "$lock_dir"' EXIT
"${cmd[@]}"
ghidra_re_release_headless_lock "$lock_dir"
trap - EXIT

printf '{\n'
printf '  "ok": true,\n'
printf '  "project_name": "%s",\n' "$project_name"
printf '  "program_name": "%s",\n' "$program_name"
printf '  "output": "%s",\n' "$export_dir"
printf '  "log": "%s",\n' "$log_file"
printf '  "script_log": "%s"\n' "$script_log"
printf '}\n'
